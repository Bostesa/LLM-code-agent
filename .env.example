# Claude API Key (get it from console.anthropic.com)
CLAUDE_API_KEY=your_api_key_here

# Claude model to use
# Options: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022
# Default: claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514

# API provider (claude or gemini)
API_PROVIDER=claude

# Path to Dafny executable (leave as "dafny" if its in your PATH)
DAFNY_PATH=dafny
